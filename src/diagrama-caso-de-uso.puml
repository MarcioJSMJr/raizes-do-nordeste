@startuml

left to right direction
actor "Cliente" as cliente
actor "Atendente" as atendente
actor "Cozinha" as cozinha
actor "Gerente / Administrador" as gerente
actor "Sistema de Pagamento" as pagamentos <<External System>>

package "Raízes do Nordeste" {

    usecase "Realizar Cadastro/Login" as UC1
    usecase "Visualizar Cardápio" as UC2
    usecase "Realizar Pedido" as UC3
    usecase "Acompanhar Status" as UC4
    usecase "Gerenciar Pontos (Fidelidade)" as UC5
    usecase "Simular Pagamento" as UC6
    usecase "Movimentar Pedido (Kanban)" as UC7
    usecase "Visualizar Fila de Preparo" as UC8
    usecase "Editar Cardápio/Relatórios" as UC9

}

cliente --> UC1
cliente --> UC2
cliente --> UC3
cliente --> UC4
cliente --> UC5
UC3 ..> UC6 : <<include>>
UC6 --> pagamentos
atendente --> UC7
cozinha --> UC8
gerente --> UC9
gerente --> UC7

@enduml

